{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "ankurmathur-web-main",
	"compatibility_date": "2026-05-03",
	"compatibility_flags": [
		"nodejs_als"
	],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"send_email": [
		{
			"name": "SEND_EMAIL"
		}
	],
	"workers_dev": true,
	"preview_urls": true
}